{
  "name": "linkedin-auto-poster",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo -H 127.0.0.1 -p ${PORT:-3005}",
    "dev:clean": "rm -rf .next && next dev --turbo -H 127.0.0.1 -p ${PORT:-3005}",
    "dev:webpack": "next dev -H 127.0.0.1 -p ${PORT:-3005}",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start -H 127.0.0.1 -p ${PORT:-3005}",
    "start:clean": "rm -rf .next && next build && next start -H 127.0.0.1 -p ${PORT:-3005}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
